# =======================================
# NextFit Monorepo .gitignore (root)
# admin/ backend/ frontend/
# =======================================

# ===============================
# Node / Dependencies
# ===============================
node_modules/
**/node_modules/
.pnp/
**/.pnp/
.pnp.js

# ===============================
# Build Outputs
# ===============================
dist/
**/dist/
build/
**/build/
out/
**/out/
.next/
**/.next/
.turbo/
**/.turbo/
.cache/
**/.cache/
.vite/
**/.vite/

# ===============================
# Environment Files (CRITICAL)
# ===============================
.env
.env.*
**/.env
**/.env.*
!.env.example
**/.env.example

# ===============================
# Logs
# ===============================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===============================
# OS Files
# ===============================
.DS_Store
Thumbs.db

# ===============================
# IDE / Editor
# ===============================
.vscode/
.idea/
*.swp
*.swo

# ===============================
# Docker
# ===============================
docker-compose.override.yml
**/docker-compose.override.yml

# Optional: local-only compose files people create
docker-compose.local.yml
**/docker-compose.local.yml

# ===============================
# Coverage / Testing
# ===============================
coverage/
**/coverage/
.nyc_output/

# ===============================
# Temporary Files
# ===============================
tmp/
temp/
*.tmp

# ===============================
# Production Artifacts
# ===============================
*.tgz

# ===============================
# Misc
# ===============================
*.pid
*.seed
*.lock-wscript

# ===============================
# Project-specific (NextFit)
# ===============================

# If you generate uploads locally
uploads/
**/uploads/

# Firebase service account should NEVER be committed
**/firebase-service-account.json

# Nginx / static artifacts (if you ever generate locally)
**/nginx.conf
**/nginx*.conf

# Docs folder if you want it ignored (you included it)
docs/