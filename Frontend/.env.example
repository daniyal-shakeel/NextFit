VITE_BACKEND_URL=your_value_here/api

# Phone auth: Firebase Phone (SMS in production; in dev use Firebase Console → Authentication → Phone → Phone numbers for testing + code from console).
# Optional: replaces the default dev hint on the Phone sign-in tab (dev builds only).
# VITE_PHONE_AUTH_DEV_HINT=

# Firebase — Project settings → Your apps → SDK config
VITE_FIREBASE_API_KEY=your_value_here
VITE_FIREBASE_AUTH_DOMAIN=your_value_here
VITE_FIREBASE_PROJECT_ID=your_value_here
VITE_FIREBASE_STORAGE_BUCKET=your_value_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_value_here
VITE_FIREBASE_APP_ID=your_value_here
