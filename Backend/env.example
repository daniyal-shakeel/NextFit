# Copy to .env and fill in values

# MongoDB
MONGODB_URI=mongodb://localhost:27017
DB_NAME=nextfit

# JWT (required for auth)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=7d

# Admin login (server-only; separate from user accounts)
# Even if a user has the same email/password, only this endpoint issues admin token.
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin123?

# CORS: optional; defaults shown (Admin typically runs on 5173)
# FRONTEND_URL=http://localhost:8080
# ADMIN_URL=http://localhost:5173

# AI description suggestion (Ollama in Docker: use http://ollama:11434 when running in compose)
# AI_SERVICE_URL=http://localhost:11434
# AI_MODEL=tinyllama

# Firebase Admin (required for phone auth - Pakistan +92)
# Use ONE of the two options below:
# Option A: Path to service account JSON file (e.g. firebase-service-account.json)
FIREBASE_SERVICE_ACCOUNT_PATH=
# Option B: Full JSON as single-line string (for hosted backends)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Dummy phone verification: allowed only when NODE_ENV=development (no env var needed)

# Cloudinary (image uploads, e.g. avatars; see config/cloudinary.ts)
# Get values from https://console.cloudinary.com/ → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (see docs/EMAIL_SETUP.md)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# APP_BASE_URL=http://localhost:5173
