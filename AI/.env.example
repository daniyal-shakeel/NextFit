# Skip model load for local testing (no GPU)
# Set false on Modal for actual inference
SKIP_MODEL_LOAD=true

# Deployment mode: local | modal
DEPLOY_MODE=local

# Model
MODEL_ID=runwayml/stable-diffusion-inpainting
MODEL_CACHE_DIR=./models

# Server
HOST=0.0.0.0
PORT=8000

# CORS
# Local: http://localhost:5173
# Modal: *
CORS_ORIGIN=http://localhost:5173

# Modal deployment specs
# GPU: T4 | L4 | A10G | A100
MODAL_GPU=L4
MODAL_CPU=4.0
MODAL_MEMORY=16384
MODAL_SCALEDOWN=300
